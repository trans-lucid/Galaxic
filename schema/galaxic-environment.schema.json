{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Galaxic Environment Manifest",
  "type": "object",
  "required": [
    "environment_id",
    "base_repo_version",
    "mode",
    "candidate_safe",
    "requires_real_credentials",
    "detected_languages",
    "profiles",
    "commands",
    "credential_policy"
  ],
  "properties": {
    "environment_id": {
      "type": "string",
      "minLength": 1
    },
    "base_repo_version": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "hermetic-local",
        "mocked-local",
        "dockerized",
        "local-cloud",
        "local-kubernetes",
        "credentialed-private"
      ]
    },
    "candidate_safe": {
      "type": "boolean"
    },
    "requires_real_credentials": {
      "type": "boolean"
    },
    "detected_languages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "confidence",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "ports": {
      "type": "object",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "commands": {
      "type": "object",
      "required": [
        "start",
        "test_public",
        "ci_local"
      ],
      "additionalProperties": {
        "type": "string"
      }
    },
    "credential_policy": {
      "type": "object",
      "required": [
        "candidate_credentials",
        "production_credentials_allowed",
        "credentialed_private_smoke_test_allowed"
      ],
      "properties": {
        "candidate_credentials": {
          "type": "string"
        },
        "production_credentials_allowed": {
          "type": "boolean"
        },
        "credentialed_private_smoke_test_allowed": {
          "type": "boolean"
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
